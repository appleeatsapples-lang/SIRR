  "EVIDENCE_RULE": {
    "policy_lock_id": "EVIDENCE_RULE",
    "version": "1.0",
    "rules": [
      "Every mapping, table, range, or formula must have either a citation OR an explicit UNCERTAIN_needs_sources marker",
      "If uncertain, produce a structured placeholder that compiles (use UNCERTAIN as string value, not null)",
      "Never fabricate a source — if you don't have the reference, say so",
      "All UNCERTAIN fields must be tracked in a separate NEEDS_VERIFICATION.json for follow-up"
    ],
    "placeholder_example": {
      "value": "UNCERTAIN_needs_sources",
      "note": "Placeholder — awaiting Tier A/B verification",
      "fallback": "Use most common community value if engine must run"
    }
  }
