  "SOURCE_TIERS": {
    "policy_lock_id": "SOURCE_TIERS",
    "version": "1.0",
    "tiers": {
      "A": {
        "label": "Primary",
        "description": "Original texts, scans, academic publications, peer-reviewed",
        "examples": [
          "Ibn Khaldun Muqaddimah",
          "Cheiro Book of Numbers 1926",
          "Surya Siddhanta",
          "Neugebauer & Parker"
        ],
        "trust": "Lock computation tables from these"
      },
      "B": {
        "label": "Respected Secondary",
        "description": "Established publishers, professional organizations, respected authors",
        "examples": [
          "Rudhyar An Astrological Mandala",
          "Mary K. Greer Tarot for Your Self",
          "Joey Yap BaZi texts"
        ],
        "trust": "Verify against Tier A if available, otherwise accept"
      },
      "C": {
        "label": "Community/Calculator",
        "description": "Blogs, apps, forums, online calculators",
        "examples": [
          "astro.com",
          "cafe astrology",
          "numerology apps"
        ],
        "trust": "Allowed as community-usage evidence ONLY. Never lock computation from Tier C alone"
      }
    },
    "enforcement": {
      "rule": "If a computation table has ONLY Tier C attestation, mark as needs_sources or modern_invention",
      "variant_creation": "Only create named variants when Tier A or B sources document different calculations"
    },
    "geomancy": {
      "tier": "A",
      "source": "Al-Zanati, Kitab al-Fasl; Agrippa, De Occulta Philosophia",
      "note": "SIRR uses JDN mod 16 for determinism. Classical Raml requires random casting of dots (odd/even). This is a declared philosophical deviation — SIRR prioritizes reproducibility over divinatory randomness. The output is deterministic Raml, not traditional Raml.",
      "gemini_flag": "Feb 2026 — Gemini flagged. Acknowledged. Deviation is intentional and documented.",
      "recommendation_taken": "DOCUMENT (not REBUILD) — SIRR cannot implement true stochastic divination"
    },
    "istikhara_adad": {
      "tier": "C",
      "source": "Al-Buni, Shams al-Ma'arif (talismanic timing methods)",
      "note": "Classical Istikhara is non-computational (prayer). This module computes abjad-date resonance as a folk-numerical analog. Not a primary-text formula. Acknowledged C-tier.",
      "gemini_flag": "Feb 2026 — Gemini flagged as Community-tier. Correct. Engine treats output accordingly.",
      "recommendation_taken": "LOWER certainty flag if needed; keep as exploratory module"
    },
    "jafr": {
      "tier": "B",
      "source": "Al-Buni general principles; Imam Ja'far attribution (pseudepigraphal)",
      "note": "No single canonical Jafr algorithm exists. SIRR implements one consistent interpretation. Results are deterministic but interpretively bounded.",
      "gemini_flag": "Feb 2026 — Gemini flagged. Acknowledged fragmented tradition.",
      "recommendation_taken": "REVIEW — keep current implementation, annotate uncertainty in output"
    }
  },
