{
  "_meta": {
    "description": "SIRR infrastructure policy locks. Codified rules for boundary handling, variant registry, fixture templates, source tiers, computability gates, and evidence requirements.",
    "version": "1.0",
    "date": "2026-02-20",
    "sources": "Consolidated from Gemini (Tasks 1-5, 7-12), ChatGPT (Tasks 1-6), Grok (3 rounds)"
  },
  "BOUNDARY_ROUNDING": {
    "policy_lock_id": "BOUNDARY_ROUNDING",
    "version": "1.0",
    "rules": {
      "degree_binning": {
        "rule": "ordinal = floor(raw_degree) + 1",
        "precision": "Use float64; never round before bin selection",
        "epsilon": "No epsilon snapping for bin selection. Epsilon (1e-10) only for display rounding",
        "applies_to": [
          "sabian",
          "decan",
          "dwad",
          "egyptian_decan",
          "manazil",
          "nakshatra"
        ]
      },
      "date_rollover": {
        "rule": "Use birth_date as provided in local time. Convert to UTC only for ephemeris calls",
        "midnight": "00:00:00 local = start of new day",
        "no_birth_time": "Default to 12:00:00 local (noon). Flag certainty as APPROX_NOON"
      },
      "calendar": {
        "rule": "Assume Gregorian for all dates after 1582-10-15",
        "pre_gregorian": "Flag as CALENDAR_UNCERTAIN if DOB before regional Gregorian adoption",
        "leap_day": "Feb 29 births use Feb 29. Never auto-shift to Feb 28 or Mar 1"
      },
      "name_normalization": {
        "arabic": {
          "hamza_alif": "إ أ آ → value of ا (1 for Abjad)",
          "ta_marbuta": "ة → value of ه (5 for Abjad)",
          "alif_maqsura": "ى → value of ي (10 for Abjad)",
          "al_prefix": "ال is counted (both alif and lam have values)",
          "diacritics": "Stripped (fatha, kasra, damma, shadda, sukun removed before computation)"
        },
        "latin": {
          "hyphens": "Stripped (Mary-Jane → MaryJane)",
          "apostrophes": "Stripped (O'Brien → OBrien)",
          "diacritics": "Normalized to base letter (é→e, ñ→n, ü→u)",
          "case": "Uppercased before lookup",
          "spaces": "Each space-separated token is a separate name part"
        }
      }
    }
  },
